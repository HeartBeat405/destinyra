# ============================================================
# Destinyra — Environment Variables
# Copy this file to `.env.local` and fill in your values.
# The app runs on seed data until these are set; once present,
# the data layer automatically switches to live Supabase.
# ============================================================

# Supabase project URL, e.g. https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon (public) key — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — SERVER ONLY. Never expose to the browser
# or commit it. Used by admin/server actions for privileged writes.
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL (used for canonical URLs, OG, sitemap, RSS)
NEXT_PUBLIC_SITE_URL=https://destinyra.vercel.app
