# ============================================================
# Destinyra — Environment Variables (TEMPLATE)
# Copy this file to `.env.local` and fill in your values there.
# NEVER put real keys in this file — it is committed to git.
# The app is live-only: without these, it shows "Installation Required".
# ============================================================

# Supabase project URL (base, NO trailing path), e.g. https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon (public) key — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — SERVER ONLY. Never expose to the browser
# or commit it. Used by admin/server actions for privileged writes.
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL (used for canonical URLs, OG, sitemap, RSS)
NEXT_PUBLIC_SITE_URL=https://destinyra.vercel.app

# Google Search Console verification code (the value from the
# <meta name="google-site-verification" content="..."> tag Google gives you).
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ----- News feed (optional) -----------------------------------
# GNews API key (free at https://gnews.io). Enables the /news page +
# homepage "Latest News". Without it, news simply stays empty.
NEWS_API_KEY=
# Search keywords for the feed (defaults to a broad wellness/lifestyle mix).
NEWS_QUERY=health OR wellness OR lifestyle OR psychology OR relationships OR mindfulness OR motivation OR self improvement
# Feed language (ISO code).
NEWS_LANG=en
# Secret that protects the /api/cron/news refresh endpoint. Set the same
# value in Vercel; Vercel Cron sends it automatically as a Bearer token.
CRON_SECRET=
